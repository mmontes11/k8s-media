{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/photoprism-.*\\/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+repository:\\s+photoprism/photoprism\\s+tag:\\s+[\"']?(?<currentValue>\\d+)[\"']?"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "photoprism/photoprism"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/infrastructure/mariadb-.*\\/mariadb\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+mariadb:(?<currentValue>[\\d.]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "library/mariadb"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "photoprism/photoprism"
      ],
      "allowedVersions": "/^[0-9]{6}$/"
    },
  {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "library/mariadb"
      ],
      "allowedVersions": "/^[0-9]+\\.[0-9]+\\.[0-9]+$/"
    }
  ]
}
