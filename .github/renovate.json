{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/photoprism-.*\\/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+repository:\\s+photoprism/photoprism\\s+tag:\\s+[\"']?(?<currentValue>\\d+)[\"']?"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "photoprism/photoprism"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "photoprism/photoprism"
      ],
      "allowedVersions": "^[0-9]+$"
    }
  ]
}
